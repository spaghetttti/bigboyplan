generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  githubId    String   @unique @map("github_id")
  githubLogin String   @map("github_login")
  email       String?
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")

  settings        UserSettings?
  plans           Plan[]
  categories      Category[]
  tasks           Task[]
  taskCompletions TaskCompletion[]
  weeklyGoals     WeeklyGoal[]
  journalEntries  JournalEntry[]
  leetcodeLogs    LeetcodeLog[]
  githubStats     GithubDailyStat[]
  checkIns        DailyCheckIn[]
  weeklyReports   WeeklyReport[]

  @@map("users")
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  leetcodeUsername String?
  githubUsername   String?
  githubToken      String?
  timezone         String   @default("UTC")
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String       @id @default(cuid())
  userId      String
  name        String
  color       String       @default("#a78bfa")
  sortOrder   Int          @default(0)
  isSystem    Boolean      @default(false)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskTags    TaskTag[]
  journalTags JournalTag[]
  weeklyGoals WeeklyGoal[]

  @@unique([userId, name])
  @@map("categories")
}

model Plan {
  id            String         @id @default(cuid())
  userId        String
  title         String
  description   String?
  startDate     String
  endDate       String?
  isActive      Boolean        @default(true)
  isArchived    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyGoals   WeeklyGoal[]
  weeklyReports WeeklyReport[]

  @@index([userId])
}

enum WeeklyGoalStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  MISSED
}

model WeeklyGoal {
  id          String           @id @default(cuid())
  userId      String
  planId      String
  categoryId  String?
  weekNumber  Int
  year        Int
  title       String
  description String?
  targetValue Int
  metricUnit  String
  actualValue Int              @default(0)
  status      WeeklyGoalStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        Plan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  category    Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, planId, weekNumber, year, title])
  @@index([userId])
}

model Task {
  id          String           @id @default(cuid())
  userId      String
  title       String
  notes       String?
  completed   Boolean          @default(false)
  isRecurring Boolean          @default(false)
  dueDate     String?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskTags    TaskTag[]
  completions TaskCompletion[]

  @@index([userId])
  @@index([userId, dueDate])
}

model TaskTag {
  taskId     String
  categoryId String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([taskId, categoryId])
}

model TaskCompletion {
  id     String @id @default(cuid())
  userId String
  taskId String
  date   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, date])
  @@index([userId])
  @@index([date])
}

model JournalEntry {
  id        String       @id @default(cuid())
  userId    String
  date      String
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags      JournalTag[]

  @@unique([userId, date])
}

model JournalTag {
  journalId  String
  categoryId String
  journal    JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  category   Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([journalId, categoryId])
}

model LeetcodeLog {
  id          String  @id @default(cuid())
  userId      String
  date        String
  easyCount   Int     @default(0)
  mediumCount Int     @default(0)
  hardCount   Int     @default(0)
  notes       String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model GithubDailyStat {
  id        String   @id @default(cuid())
  userId    String
  date      String
  commits   Int      @default(0)
  prs       Int      @default(0)
  reviews   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  date      String
  checkedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model WeeklyReport {
  id          String   @id @default(cuid())
  userId      String
  planId      String?
  weekNumber  Int
  year        Int
  snapshot    Json
  generatedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@unique([userId, weekNumber, year])
  @@index([userId])
}
